---
import logo from '@/assets/logo.svg';
import { Search } from '@/components/Search';
import { ThemeToggle } from '@/components/ThemeToggle';
import { MobileNav } from '@/components/MobileNav';
import { Github } from 'lucide-react';
import type { NavGroup } from '@/lib/nav';

interface Props {
  nav: NavGroup[];
  currentSlug?: string;
}

const { nav, currentSlug = '' } = Astro.props;
---

<header class="sticky top-0 z-40 border-b border-border bg-background/90 backdrop-blur-md">
  <div class="flex h-14 items-center gap-2 px-3 sm:h-16 sm:gap-3 sm:px-6">
    <MobileNav client:load nav={nav} currentSlug={currentSlug} />

    <a href="/" class="flex min-w-0 shrink items-center gap-2 sm:gap-2.5">
      <img src={logo.src} alt="node-sisp" width="30" height="30" class="shrink-0 rounded-lg" />
      <span class="truncate text-[16px] font-bold tracking-tight sm:text-[17px]">node-sisp</span>
      <span
        class="hidden rounded-full bg-accent px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-accent-foreground sm:inline-flex"
      >
        Docs
      </span>
    </a>

    <div class="ml-auto flex shrink-0 items-center justify-end gap-1.5">
      <Search client:load />

      <ThemeToggle client:load />

      <a
        href="https://github.com/akira-io/node-sisp"
        aria-label="Open GitHub repository"
        class="ml-1 hidden size-9 items-center justify-center rounded-full border border-border bg-muted/50 text-muted-foreground transition-colors hover:border-primary/50 hover:text-foreground md:inline-flex"
      >
        <Github aria-hidden="true" className="size-4" />
      </a>
    </div>
  </div>
  <div class="border-t border-border/70 bg-accent/60 px-3 py-2 sm:px-6">
    <div class="mx-auto flex max-w-[90rem] items-start gap-2 text-xs leading-5 text-muted-foreground sm:items-center sm:text-sm">
      <span class="inline-flex shrink-0 rounded-full bg-primary/10 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-primary">
        Beta
      </span>
      <p>
        <span class="font-medium text-foreground">@akira-io/sisp beta documentation.</span> APIs may change before
        the stable release.
      </p>
    </div>
  </div>
</header>
